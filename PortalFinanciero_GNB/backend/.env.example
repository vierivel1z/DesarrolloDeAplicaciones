# Conexión a la base PostgreSQL YA EXISTENTE (compartida con el core bancario)
DATABASE_URL=postgresql://postgres:123456789@localhost:5432/bd_core_financiero

# Seguridad JWT
SECRET_KEY=cambia-esta-clave-por-una-larga-y-aleatoria
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Servidor (el core corre en 8001; este portal en 8002)
PORT=8002

# CORS: orígenes permitidos separados por coma (frontend React/Vite)
# 5173 = portal del personal · 5174 = portal del cliente (este Homebanking)
CORS_ORIGINS=http://localhost:5173,http://localhost:5174
